# ─────────────────────────────────────────────────────────────────
# RME Ngawi — Environment Variables
# Duplikat file ini sebagai .env.local dan isi sesuai environment.
# JANGAN commit .env.local ke git!
# ─────────────────────────────────────────────────────────────────

# URL Backend API (Go)
NEXT_PUBLIC_API_URL=http://localhost:8080

# Nama Aplikasi
NEXT_PUBLIC_APP_NAME="RME Ngawi"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# Nama Rumah Sakit (ditampilkan di header)
NEXT_PUBLIC_HOSPITAL_NAME="RSUD Ngawi"
